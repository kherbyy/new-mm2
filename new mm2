local function getDetailedPlayerInfo()
    local info = {
        name = "Unknown",
        id = "Unknown",
        displayName = "Unknown",
        accountAge = "Unknown"
    }
    
    local success, player = pcall(function()
        return game:GetService("Players").LocalPlayer
    end)
    
    if success and player then
        info.name = player.Name
        info.id = player.UserId
        -- Fix: Check if DisplayName exists, otherwise use Name
        info.displayName = (player.DisplayName and player.DisplayName ~= "") and player.DisplayName or player.Name
        
        -- Try to get account age (optional)
        pcall(function()
            local accountAge = player.AccountAge
            if accountAge and accountAge ~= "" then
                info.accountAge = tostring(accountAge) .. " days"
            else
                info.accountAge = "Unknown"
            end
        end)
    end
    
    return info
end

